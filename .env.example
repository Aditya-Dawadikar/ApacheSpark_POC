# Copy this file to .env and adjust as needed. docker-compose.yml loads .env
# automatically for the spark-worker and spark-job services (env_file: .env).
# See README.md's "Configuration" section for what each variable does.

# --- Application / output (spark-job) ---
SPARK_APP_NAME=spark-app
OUTPUT_FORMAT=csv
SPARK_SHUFFLE_PARTITIONS=4

# --- Executor sizing (spark-job) ---
# Executor count = SPARK_CORES_MAX / SPARK_EXECUTOR_CORES. Defaults below give
# up to 4 executors of 1 core / 1g each.
SPARK_EXECUTOR_CORES=1
SPARK_EXECUTOR_MEMORY=1g
SPARK_CORES_MAX=4

# --- Worker capacity (spark-worker) ---
# Must be able to supply at least SPARK_CORES_MAX cores and
# (executors x SPARK_EXECUTOR_MEMORY) memory, or fewer executors than
# requested will actually launch.
SPARK_WORKER_CORES=4
SPARK_WORKER_MEMORY=4g
